{
  "name": "cdk-template-typescript",
  "version": "1.0.0",
  "description": "A CDK Node.js TypeScript template",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc && esbuild src/index.ts --bundle --platform=node --outdir=dist",
    "lint": "eslint . --color",
    "prettier": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "watch": "tsc -w",
    "prepare": "husky",
    "cdk": "cdk"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.4",
    "aws-cdk": "2.1121.0",
    "esbuild": "0.28.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.252.0",
    "constructs": "10.6.0"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown .",
    "*.ts": "eslint --color --fix --max-warnings=0"
  },
  "volta": {
    "node": "24.15.0",
    "npm": "11.14.1"
  }
}
